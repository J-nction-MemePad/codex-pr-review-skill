{
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings"],
  "properties": {
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "detail", "evidence", "file", "line", "category", "confidence"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["Blocker", "Major", "Minor", "Question"]
          },
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "file": {
            "type": ["string", "null"]
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "category": {
            "type": "string"
          },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
